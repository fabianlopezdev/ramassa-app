{
  "name": "ramassa",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && bun run --cwd packages/shared typecheck && bun run --cwd apps/mobile typecheck && bun run --cwd apps/admin typecheck",
    "test": "bun test",
    "mobile:ios": "bun run --cwd apps/mobile ios",
    "mobile:android": "bun run --cwd apps/mobile android",
    "mobile:start": "bun run --cwd apps/mobile start",
    "admin:dev": "bun run --cwd apps/admin dev",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db",
    "db:types": "supabase gen types typescript --local > packages/shared/types/database.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/bun": "^1.3.14",
    "eslint": "^10.7.0",
    "eslint-plugin-i18next": "6.1.5",
    "globals": "^17.7.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "trustedDependencies": [
    "@sentry/cli"
  ]
}
