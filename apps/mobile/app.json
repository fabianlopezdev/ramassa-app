{
  "expo": {
    "name": "Ramassà",
    "slug": "ramassa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ramassa",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.fabs-and.ramassa"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.fabsand.ramassa"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-localization",
      [
        "expo-font",
        {
          "ios": {
            "fonts": [
              "./assets/fonts/NotoKufiArabic-Regular.ttf",
              "./assets/fonts/NotoKufiArabic-Bold.ttf",
              "./assets/fonts/Vazirmatn-Regular.ttf",
              "./assets/fonts/Vazirmatn-Bold.ttf"
            ]
          },
          "android": {
            "fonts": [
              {
                "fontFamily": "Noto Kufi Arabic",
                "fontDefinitions": [
                  { "path": "./assets/fonts/NotoKufiArabic-Regular.ttf", "weight": 400 },
                  { "path": "./assets/fonts/NotoKufiArabic-Bold.ttf", "weight": 700 }
                ]
              },
              {
                "fontFamily": "Vazirmatn",
                "fontDefinitions": [
                  { "path": "./assets/fonts/Vazirmatn-Regular.ttf", "weight": 400 },
                  { "path": "./assets/fonts/Vazirmatn-Bold.ttf", "weight": 700 }
                ]
              }
            ]
          }
        }
      ]
    ],
    "extra": {
      "supportsRTL": true
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "newArchEnabled": true
  }
}
