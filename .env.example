# Copy to .env and fill in real values. NEVER commit .env (gitignored).
# Supabase (local dev via `bunx supabase start`; prod = Frankfurt project)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sentry (RAPP-12). DSNs are ingest addresses, not secrets.
# Mobile project DSN (Sentry project `react-native`, EU):
EXPO_PUBLIC_SENTRY_DSN=
# Admin project DSN (Sentry project `ramassa-admin`, EU):
VITE_SENTRY_DSN=
SENTRY_DSN=
# Org auth token for source-map upload (SECRET — local .env and EAS/CI secrets only):
SENTRY_AUTH_TOKEN=
